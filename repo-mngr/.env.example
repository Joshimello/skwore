PORT=8080

# Claude Code auth — OAuth token from `claude setup-token` (sk-ant-oat01-...)
# Passed into the grader container as CLAUDE_CODE_OAUTH_TOKEN.
ANTHROPIC_API_KEY=

# Grading container image (built from grader/Dockerfile)
DOCKER_IMAGE=grader-image:latest

# Job limits
MAX_CONCURRENT_JOBS=4
JOB_TIMEOUT=300

# Shared secret for webhook HMAC-SHA256 signature
WEBHOOK_SECRET=

# Where job working dirs live (repo clones + grader output).
# Must be the same absolute path on the host AND inside this container.
# Use an absolute path to this folder's data/ subdir to avoid polluting the host:
#   DATA_DIR=/absolute/path/to/repo-mngr/data/jobs
DATA_DIR=

# Cloudflare preview tunnels
# 1. Run: cloudflared tunnel create repo-manager-previews
# 2. Add wildcard DNS: *.preview.yourdomain.com → <uuid>.cfargotunnel.com
# 3. Copy tunnel credentials JSON into the container (see Dockerfile)
CLOUDFLARE_TUNNEL_NAME=repo-manager-previews
PREVIEW_DOMAIN=preview.yourdomain.com
PREVIEW_PORT_MIN=30000
PREVIEW_PORT_MAX=39999
PREVIEW_TTL_SECONDS=14400
