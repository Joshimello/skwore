# Drizzle
# Replace with your DB credentials!
DATABASE_URL="postgres://user:password@host:port/db-name"

ORIGIN=""

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""
# Google OAuth
# https://www.better-auth.com/docs/authentication/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Comma-separated list of emails allowed to access the app
ALLOWED_EMAILS=""

# Comma-separated list of admin emails (will be auto-promoted to admin role)
ADMIN_EMAILS=""

# Repo Manager microservice
REPO_MANAGER_URL="http://localhost:8080"
REPO_MANAGER_WEBHOOK_SECRET=""
# URL the repo manager container uses to call back — must be reachable from inside Docker
# On macOS/Windows Docker Desktop use host.docker.internal; on Linux use the host IP
WEBHOOK_BASE_URL="http://host.docker.internal:5173"
